      "boundElements": [],
      "updated": 1777345460445,
      "link": null,
      "locked": false,
      "text": "Note: If lock goes down, we will immediately bring another up\nbut in that mean time (10 minutes) other many user will go to payment page.\nSince we have postgress db and we have acid properties,\nwhosoever reaches there first will complete the booking. \nUsers will have a bad experience but we will need to discuss \nwith product.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: If lock goes down, we will immediately bring another up\nbut in that mean time (10 minutes) other many user will go to payment page.\nSince we have postgress db and we have acid properties,\nwhosoever reaches there first will complete the booking. \nUsers will have a bad experience but we will need to discuss \nwith product.",
      "autoResize": true,
      "lineHeight": 1.25
    },
